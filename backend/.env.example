# Environment Configuration for Shree Bhramani Enterprise Backend
# Copy this file to .env and fill in your values

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================================
# The email address that will SEND notifications (your Gmail)
EMAIL_USER=your_gmail@gmail.com
# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_app_password_here

# The email address that RECEIVES notifications (business email)
NOTIFY_EMAIL=sales@shreebhramani.in

# ============================================================
# SECURITY
# ============================================================
# Secret key for any token-based operations
SECRET_KEY=change_this_to_a_random_secret_key_in_production

# ============================================================
# CORS (Allowed frontend origins)
# ============================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://shreebhramani.in

# ============================================================
# OPTIONAL: Firebase (for future database upgrade)
# ============================================================
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=your-client-email
# FIREBASE_PRIVATE_KEY="your-private-key"
